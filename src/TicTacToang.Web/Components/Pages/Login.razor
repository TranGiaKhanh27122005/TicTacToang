@page "/login"
@inject PlayerService Players
@inject UserSession Session
@inject NavigationManager Navigation
@inject Microsoft.JSInterop.IJSRuntime JS

<div class="auth-screen">
    <section class="auth-panel">
        <div class="logo-mark">TT</div>
        <h1>Sign in</h1>
        <p class="muted">Enter the arena and continue your matches.</p>
        <label>Username or email</label>
        <input @bind="_identity" autocomplete="off" />
        <label>Password</label>
        <input @bind="_password" type="password" autocomplete="new-password" />
        @if (_error is not null) { <p class="alert-error">@_error</p> }
        <button class="primary" @onclick="LoginAsync">Sign in</button>
        <p class="auth-foot">New player? <a href="/register">Create account</a></p>
    </section>
</div>

@code {
    private string _identity = "";
    private string _password = "";
    private string? _error;
    private bool _restoreChecked;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || _restoreChecked)
        {
            return;
        }

        _restoreChecked = true;
        try
        {
            var storedJson = await JS.InvokeAsync<string?>("ticTacAuth.get");
            if (string.IsNullOrWhiteSpace(storedJson))
            {
                return;
            }

            var storedAuth = System.Text.Json.JsonSerializer.Deserialize<AuthResult>(storedJson);
            var player = Players.ResolveToken(storedAuth?.Token);
            if (storedAuth is null || player is null || !player.IsActive)
            {
                await JS.InvokeVoidAsync("ticTacAuth.clear");
                return;
            }

            Session.SignIn(new AuthResult(player, storedAuth.Token));
            Navigation.NavigateTo("/main-menu", replace: true);
        }
        catch (System.Text.Json.JsonException)
        {
            await JS.InvokeVoidAsync("ticTacAuth.clear");
        }
    }

    private async Task LoginAsync()
    {
        try
        {
            var auth = await Players.LoginAsync(new LoginRequest(_identity, _password));
            Session.SignIn(auth);
            await JS.InvokeVoidAsync("ticTacAuth.set", System.Text.Json.JsonSerializer.Serialize(auth));
            Navigation.NavigateTo("/main-menu");
        }
        catch (Exception ex) { _error = ex.Message; }
    }
}
