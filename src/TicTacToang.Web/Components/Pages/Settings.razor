@page "/settings"
@page "/setting-page"
@inject UserSession Session
@inject NavigationManager Navigation

<a class="return-button" href="/main-menu">Back to Menu</a>
<header class="page-title"><div><p class="eyebrow">SYSTEM</p><h1>Settings</h1></div></header>
<section class="form-panel narrow">
    <label class="toggle"><input type="checkbox" checked /> Notifications</label>
    <label class="toggle"><input type="checkbox" checked /> Game sounds</label>
    <label>Theme<select><option>Dark</option><option>Light</option></select></label>
    <button class="danger" @onclick="Logout">Log out</button>
</section>

@code {
    protected override void OnInitialized() { if (!Session.IsAuthenticated) Navigation.NavigateTo("/login"); }
    private void Logout() { Session.SignOut(); Navigation.NavigateTo("/login"); }
}
