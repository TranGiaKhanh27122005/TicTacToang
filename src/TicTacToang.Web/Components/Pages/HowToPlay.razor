@page "/how-to-play"

<style>
.how-page{width:min(980px,calc(100% - 1rem));margin:0 auto;padding:.2rem 0 3rem}
.how-back{margin-bottom:0}
.how-shell{padding:2.3rem 2rem 2.7rem;border:1px solid rgba(122,162,255,.17);border-radius:28px;background:linear-gradient(180deg,rgba(18,26,56,.88),rgba(8,13,32,.88));box-shadow:0 22px 58px rgba(0,0,0,.28)}
.how-shell>h1{margin:0 0 2.2rem;color:#fff;background:none;text-align:center;font-size:4rem;text-shadow:none}
.how-rule-list{display:grid;gap:1.35rem}
.how-rule{min-height:130px;display:grid;grid-template-columns:58px minmax(0,1fr);align-items:start;gap:1.25rem;padding:1.5rem;border:1px solid rgba(122,162,255,.14);border-radius:24px;background:rgba(9,15,37,.42)}
.how-rule-icon{width:54px;height:54px;display:grid;place-items:center;border-radius:999px;background:rgba(44,77,156,.48)}
.how-rule-icon svg{width:27px;height:27px;fill:#5f9cff}
.how-rule h2{margin:.2rem 0 .75rem;color:#fff;font-size:1.45rem}.how-rule p{margin:0;color:#96a3c7;line-height:1.6}
.how-example{margin-top:1.35rem;padding:1.5rem;border:1px solid rgba(122,162,255,.14);border-radius:24px;background:rgba(9,15,37,.42)}
.how-example h2{margin:0 0 1.5rem;color:#fff;font-size:1.35rem}
.how-board{width:244px;aspect-ratio:1;display:grid;grid-template-columns:repeat(5,1fr);gap:5px;margin:0 auto;padding:1rem;border-radius:24px;background:rgba(5,10,29,.7)}
.how-cell{display:grid;place-items:center;border:1px solid rgba(255,255,255,.05);border-radius:14px;background:rgba(29,36,67,.7);font-size:1.55rem;font-weight:900}.how-cell.x{color:#65a0ff}.how-cell.o{color:#ba68ff}
.how-caption{margin:1rem 0 0;color:#95a2c6;text-align:center}
@@media(max-width:650px){.how-shell{padding:1.5rem 1rem}.how-shell>h1{font-size:3rem}.how-rule{grid-template-columns:48px minmax(0,1fr);padding:1.1rem}.how-rule-icon{width:46px;height:46px}.how-board{width:min(244px,100%)}}
</style>

<div class="how-page">
<a class="return-button how-back" href="/main-menu">Back to Menu</a>
<main class="how-shell">
<h1>How to Play</h1>
<div class="how-rule-list">
<section class="how-rule"><span class="how-rule-icon" aria-hidden="true"><svg viewBox="0 0 24 24"><path d="M12 2a10 10 0 1 0 0 20 10 10 0 0 0 0-20zm0 3a7 7 0 1 1 0 14 7 7 0 0 1 0-14zm0 3a4 4 0 1 0 0 8 4 4 0 0 0 0-8zm0 2a2 2 0 1 1 0 4 2 2 0 0 1 0-4z"/></svg></span><span><h2>Objective</h2><p>Be the first player to place five of your markers in one continuous row: horizontally, vertically, or diagonally.</p></span></section>
<section class="how-rule"><span class="how-rule-icon" aria-hidden="true"><svg viewBox="0 0 24 24"><path d="M8 11a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm8-1a3 3 0 1 1 0-6 3 3 0 0 1 0 6zM1 20v-2c0-3.3 4.7-5 7-5s7 1.7 7 5v2H1zm15 0v-2c0-1.5-.5-2.8-1.4-3.8.5-.1 1-.2 1.4-.2 2.3 0 7 1.4 7 4v2h-7z"/></svg></span><span><h2>Players</h2><p>Two or three players take turns placing their markers on a 10 x 10 or 15 x 15 board. A player may only place a marker on an empty tile.</p></span></section>
<section class="how-rule"><span class="how-rule-icon" aria-hidden="true"><svg viewBox="0 0 24 24"><path d="M18 2h3v2c0 3.5-1.8 5.7-5 6.6A6.2 6.2 0 0 1 13 13v3h4v2H7v-2h4v-3a6.2 6.2 0 0 1-3-2.4C4.8 9.7 3 7.5 3 4V2h3V1h12v1zM5 4c0 2 .7 3.3 2 4V4H5zm12 4c1.3-.7 2-2 2-4h-2v4zM9 3v4a3 3 0 0 0 6 0V3H9zm-4 17h14v2H5v-2z"/></svg></span><span><h2>Winning</h2><p>The match ends immediately when one marker forms a straight line of five. A full board without a winning line is recorded as a draw.</p></span></section>
</div>
<section class="how-example"><h2>Example Game</h2><div class="how-board" aria-label="Example five in a row board">@foreach(var marker in ExampleBoard){<span class="@($"how-cell {marker.ToLowerInvariant()}")">@marker</span>}</div><p class="how-caption">Player X wins with a diagonal line.</p></section>
</main>
</div>

@code{private static readonly string[] ExampleBoard=["X","O","","","","","X","","O","O","","","X","O","","","O","","X","","","","","","X"];}
