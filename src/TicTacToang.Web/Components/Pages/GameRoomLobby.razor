@page "/gameroom/{RoomId:guid}"
@inject RoomService Rooms
@inject UserSession Session
@inject NavigationManager Navigation

@if (_room is not null)
{
    <div class="game-room-page">
        <a class="game-room-back" href="/main-menu"><span>&lt;</span>Back</a>

        <header class="game-room-title">
            <p>Room ID: @_room.RoomCode</p>
            <span>@_room.Capacity Players</span>
        </header>

        <a class="game-room-settings" href="/settings" aria-label="Settings">
            <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 8.2a3.8 3.8 0 1 0 0 7.6 3.8 3.8 0 0 0 0-7.6zm8.7 3.8c0 .5 0 1-.1 1.4l2 1.6-2 3.5-2.5-1a8.1 8.1 0 0 1-2.4 1.4l-.4 2.7H8.7l-.4-2.7a8.1 8.1 0 0 1-2.4-1.4l-2.5 1-2-3.5 2-1.6A9 9 0 0 1 3.3 12c0-.5 0-1 .1-1.4l-2-1.6 2-3.5 2.5 1a8.1 8.1 0 0 1 2.4-1.4l.4-2.7h6.6l.4 2.7a8.1 8.1 0 0 1 2.4 1.4l2.5-1 2 3.5-2 1.6c.1.4.1.9.1 1.4z" /></svg>
        </a>

        <main class="game-room-stage">
            <section class="player-card">
                <div class="avatar-frame">
                    <img src="@HostAvatar" alt="@HostName avatar" />
                    <span class="owner-crown">♕</span>
                </div>
                <div class="player-name-row">
                    <strong>@HostName</strong>
                    <span class="marker-pill">@_room.Settings.Marker</span>
                    <span class="style-pill">@_room.Settings.BoardStyle[0]</span>
                </div>
            </section>

            <div class="vs-card">VS</div>

            <section class="open-seat">
                @if (CanAddAi)
                {
                    <button type="button" @onclick="AddAiAsync" aria-label="Add AI player">+</button>
                }
                else
                {
                    <span>+</span>
                }
            </section>
        </main>

        <aside class="friends-online">
            <header>
                <h2>Friends Online</h2>
                <span>0 of 0 online</span>
            </header>
            <div>
                <strong>No friends available</strong>
                <p>Add friends from the main menu.</p>
            </div>
        </aside>

        <section class="game-room-chat">
            <h2>Chat History</h2>
            <div class="chat-history">
                @if (_room.ChatMessages.Count == 0)
                {
                    <p>No messages yet. Start chatting here.</p>
                }
                else
                {
                    @foreach (var message in _room.ChatMessages.TakeLast(8))
                    {
                        <p><strong>@message.SenderName:</strong> @message.Text</p>
                    }
                }
            </div>
            <div class="chat-entry">
                <input @bind="_message" @bind:event="oninput" placeholder="Type a message..." />
                <button type="button" @onclick="SendAsync" aria-label="Send message">
                    <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M3 20.5 22 12 3 3.5v6.6l11.5 1.9L3 13.9v6.6z" /></svg>
                </button>
            </div>
        </section>

        <button type="button" class="start-game-button" disabled="@(!CanStart)" @onclick="StartAsync">
            <span>▶</span>
            Start Game
        </button>

        @if (_error is not null)
        {
            <p class="game-room-error">@_error</p>
        }
    </div>
}

@code {
    [Parameter] public Guid RoomId { get; set; }

    private GameRoom? _room;
    private string _message = "";
    private string? _error;

    private RoomMember? Host => _room?.Members.FirstOrDefault(member => member.PlayerId == _room.HostId) ?? _room?.Members.FirstOrDefault();
    private string HostName => Host?.Name ?? "Host";
    private string HostAvatar => string.IsNullOrWhiteSpace(Host?.Avatar) ? "/Mambo.png" : Host!.Avatar;
    private bool IsHost => _room?.HostId == Session.Player?.Id;
    private bool CanAddAi => IsHost && _room is { Status: RoomStatus.Available } && _room.Members.Count < _room.Capacity;
    private bool CanStart => IsHost && _room is not null && _room.Members.Count >= 2;

    protected override void OnParametersSet()
    {
        if (!Session.IsAuthenticated)
        {
            Navigation.NavigateTo("/login");
            return;
        }

        LoadRoom();
    }

    private void LoadRoom()
    {
        try
        {
            _room = Rooms.Get(RoomId);
            _error = null;
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
    }

    private async Task AddAiAsync()
    {
        try
        {
            _room = await Rooms.AddAiAsync(RoomId, Session.Player!.Id, AiDifficulty.Medium);
            _error = null;
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
    }

    private async Task SendAsync()
    {
        if (string.IsNullOrWhiteSpace(_message) || _room is null)
        {
            return;
        }

        await Rooms.PostChatAsync(_room.Id, Session.Player!.Id, _message);
        _message = "";
        LoadRoom();
    }

    private async Task StartAsync()
    {
        try
        {
            var match = await Rooms.StartAsync(RoomId, Session.Player!.Id);
            Navigation.NavigateTo($"/game/{match.Id}");
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
    }
}
