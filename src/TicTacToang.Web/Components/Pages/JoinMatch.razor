@page "/join-match"
@inject RoomService Rooms
@inject UserSession Session
@inject NavigationManager Navigation

<style>
.join-page{width:min(1160px,calc(100% - 1rem));margin:0 auto;padding:.2rem 0 3rem}
.join-back{margin-bottom:0;border-color:rgba(255,255,255,.45)}
.join-shell{overflow:hidden;border:1px solid rgba(122,162,255,.18);border-radius:26px;background:linear-gradient(180deg,rgba(35,42,83,.86),rgba(9,14,34,.88));box-shadow:0 22px 58px rgba(0,0,0,.28)}
.join-hero{display:grid;justify-items:center;gap:1.4rem;padding:2.2rem 2rem 3.2rem;text-align:center;border-bottom:1px solid rgba(255,255,255,.07)}
.join-kicker{display:inline-flex;align-items:center;gap:.55rem;padding:.45rem 1rem;border:1px solid rgba(165,222,255,.56);border-radius:999px;background:rgba(32,72,111,.42);color:#9ce9ff;font-size:.76rem;font-weight:900;letter-spacing:.18em;text-transform:uppercase}
.join-hero h1{margin:0;color:#fff;background:none;font-size:4.1rem;text-shadow:none}
.join-hero p{max-width:720px;margin:0;color:#b7c0dc;font-size:1.05rem;font-weight:650}
.join-content{display:grid;grid-template-columns:minmax(0,1.1fr) minmax(340px,.9fr);gap:1.4rem;padding:2.5rem}
.join-panel{min-width:0;min-height:540px;padding:2.4rem;border:1px solid rgba(122,162,255,.17);border-radius:22px;background:rgba(8,13,32,.42)}
.join-panel-heading{display:flex;align-items:center;justify-content:space-between;gap:1rem;margin-bottom:2rem}
.join-panel-heading h2{margin:0 0 .45rem;color:#fff;font-size:1.8rem}.join-panel-heading p{margin:0;color:#909dbf}
.join-count{flex:0 0 auto;padding:.35rem .8rem;border:1px solid rgba(255,255,255,.48);border-radius:999px;color:#b8c4e5;font-size:.78rem;font-weight:800}
.join-room-grid{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:1rem}
.join-room-card{min-width:0;min-height:220px;display:grid;align-content:space-between;gap:1rem;padding:1.25rem;border:1px solid rgba(255,255,255,.52);border-radius:18px;background:rgba(30,36,65,.72);text-align:left}
.join-room-card:hover{transform:translateY(-3px)}
.join-room-top{display:flex;align-items:flex-start;justify-content:space-between;gap:.7rem}.join-room-top strong{overflow-wrap:anywhere;color:#fff;font-size:1.15rem}.join-available{padding:.25rem .55rem;border:1px solid rgba(103,232,183,.5);border-radius:999px;background:rgba(46,127,101,.25);color:#9df0cf;font-size:.68rem}
.join-room-code{color:#7d89ac;font-size:.8rem;letter-spacing:.15em}.join-room-meta{display:flex;align-items:center;justify-content:space-between;gap:.6rem;color:#c5cee8;font-size:.88rem}.join-room-meta span:last-child{color:#8aaeff}
.join-empty{padding:2rem;border:1px dashed rgba(255,255,255,.25);border-radius:18px;color:#909dbf;text-align:center}
.join-code-card,.join-tip{padding:1.7rem;border:1px solid rgba(255,255,255,.55);border-radius:18px;background:rgba(32,38,68,.58)}
.join-code-card label{color:#dfe5fa}.join-code-card input{min-height:58px;margin:1rem 0 1.25rem;border-color:rgba(255,255,255,.5);border-radius:999px}.join-submit{width:100%;min-height:58px;border:0;border-radius:999px;background:linear-gradient(90deg,#527cff,#a148ff)}
.join-tip{margin-top:2rem;border-color:rgba(143,177,255,.38);background:rgba(16,38,62,.54)}.join-tip strong{display:block;margin-bottom:1rem;color:#8de9ee}.join-tip p{margin:0;color:#9aa7c8;line-height:1.65}
.join-error{margin:1rem 0 0}
@@media(max-width:900px){.join-content{grid-template-columns:1fr;padding:1.2rem}.join-panel{min-height:0;padding:1.4rem}.join-hero h1{font-size:3rem}}
@@media(max-width:560px){.join-room-grid{grid-template-columns:1fr}.join-hero{padding:1.5rem 1rem 2.2rem}.join-panel-heading{align-items:flex-start}.join-count{white-space:nowrap}}
</style>

<div class="join-page">
<a class="return-button join-back" href="/main-menu">Back to Menu</a>
<main class="join-shell">
<header class="join-hero"><span class="join-kicker">Multiplayer Lobby</span><h1>Join a Match</h1><p>Enter a room code directly or choose an active lobby below to jump into the game.</p></header>
<div class="join-content">
<section class="join-panel">
<header class="join-panel-heading"><div><h2>Active Rooms</h2><p>Choose a lobby with available slots.</p></div><span class="join-count">@AvailableRooms.Count room@(AvailableRooms.Count == 1 ? "" : "s") live</span></header>
@if(AvailableRooms.Count==0){<div class="join-empty">No public rooms are available right now.</div>}
else{<div class="join-room-grid">@foreach(var room in AvailableRooms){<button type="button" class="join-room-card" @onclick="()=>JoinAsync(room)"><span class="join-room-top"><strong>@room.Name</strong><small class="join-available">Available</small></span><span class="join-room-code">@room.RoomCode</span><span class="join-room-meta"><span>@room.Members.Count/@room.Capacity players</span><span>@room.Settings.BoardSize x @room.Settings.BoardSize</span></span></button>}</div>}
</section>
<section class="join-panel">
<header class="join-panel-heading"><div><h2>Join with Room Code</h2><p>Use the code shared by your friend to join a private room instantly.</p></div></header>
<div class="join-code-card"><label>Room Code<input @bind="_roomCode" inputmode="numeric" placeholder="Enter room code" /></label><button type="button" class="join-submit" @onclick="JoinByCodeAsync">Join Room</button></div>
<aside class="join-tip"><strong>Tip</strong><p>Public rooms are listed on the left. Private matches require the six-digit room code from the host.</p></aside>
@if(_error is not null){<p class="alert-error join-error">@_error</p>}
</section>
</div>
</main>
</div>

@code{
private string _roomCode="";private string? _error;
private IReadOnlyList<GameRoom> AvailableRooms=>Rooms.List().Where(room=>room.Status==RoomStatus.Available&&room.Members.Count<room.Capacity).ToList();
protected override void OnInitialized(){if(!Session.IsAuthenticated)Navigation.NavigateTo("/login");}
private async Task JoinAsync(GameRoom room){try{var joined=await Rooms.JoinAsync(room.Id,Session.Player!.Id);Navigation.NavigateTo($"/gameroom/{joined.Id}");}catch(Exception ex){_error=ex.Message;}}
private async Task JoinByCodeAsync(){if(!int.TryParse(_roomCode.Trim(),out var code)){_error="Enter a valid numeric room code.";return;}var room=Rooms.List().FirstOrDefault(item=>item.RoomCode==code);if(room is null){_error="Room code not found.";return;}await JoinAsync(room);}
}
