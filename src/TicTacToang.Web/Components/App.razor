<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="/" />
    <title>TicTacToang | Five in a Row</title>
    <link rel="stylesheet" href="@Assets["lib/bootstrap/dist/css/bootstrap.min.css"]" />
    <link rel="stylesheet" href="@Assets["app.css"]" />
    <link rel="stylesheet" href="@Assets["TicTacToang.Web.styles.css"]" />
    <style>
        html[data-theme="light"] {
            --text: #17203a;
            --muted: #586582;
            --border: rgba(42, 57, 98, .18);
        }

        html[data-theme="light"] body {
            background: linear-gradient(135deg, #edf3ff 0%, #e4e9fb 52%, #dcd7fa 100%);
        }
    </style>
    <ImportMap />
    <link rel="icon" type="image/png" href="favicon.png" />
    <HeadOutlet />
</head>

<body>
    <Routes @rendermode="InteractiveServer" />
    <script>
        window.ticTacTheme = {
            get: function () {
                return localStorage.getItem("tictactoang-theme") || "dark";
            },
            set: function (theme) {
                document.documentElement.dataset.theme = theme;
                localStorage.setItem("tictactoang-theme", theme);
            }
        };
        window.ticTacAuth = {
            get: function () {
                return localStorage.getItem("tictactoang-auth");
            },
            set: function (authJson) {
                localStorage.setItem("tictactoang-auth", authJson);
            },
            clear: function () {
                localStorage.removeItem("tictactoang-auth");
            }
        };
        document.documentElement.dataset.theme = window.ticTacTheme.get();
    </script>
    <script src="_framework/blazor.web.js"></script>
</body>

</html>
